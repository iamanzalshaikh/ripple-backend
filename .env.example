NODE_ENV=development
PORT=3001
FRONTEND_URL=http://localhost:8081

# PostgreSQL (Neon) — pooled URL from Neon dashboard, e.g.:
# postgresql://USER:PASS@ep-xxx-pooler.region.aws.neon.tech/neondb?sslmode=require
# Do NOT add channel_binding=require (breaks Prisma on Windows).
DATABASE_URL=

JWT_ACCESS_SECRET=change-me-access-min-32-chars-recommended
JWT_REFRESH_SECRET=change-me-refresh-min-32-chars-recommended

# Optional — defaults to "token" (Ridez-style httpOnly cookie)
# AUTH_COOKIE_NAME=token

# OpenAI (Phase 1 AI endpoints)
OPENAI_API_KEY=
# Force English transcription (ISO-639-1). Omit to let Whisper auto-detect.
WHISPER_LANGUAGE=en
# LLM timeout in ms (default 90000 — long voice commands need more than 10s)
AI_TIMEOUT_MS=90000

# Cloudinary (store audio/uploads)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

